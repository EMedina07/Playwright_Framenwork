{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node", "@cucumber/cucumber"]
  },
  "include": [
    "**/*.ts",
    "cucumber.js"
   ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
