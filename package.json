{
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.3.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0"
  },
  "scripts": {
    "test": "cucumber-js",
    "test:qa": "node scripts/run-tests.js qa",
    "test:qa:video": "node scripts/run-tests.js qa RECORD_VIDEO=true",
    "test:qa:video:report": "node scripts/run-tests.js qa RECORD_VIDEO=true",
    "test:cert": "node scripts/run-tests.js cert",
    "report": "ts-node --transpile-only report.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
